generator client {
  provider   = "prisma-client"
  output     = "./generated"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
  url      = env("DB_FILE_NAME")
}

model User {
  // Adaptive AI platform columns (do not change)
  id     String  @id
  name   String?
  image  String?
  handle String?
}

model HOA {
  id          String   @id @default(cuid())
  name        String
  community   String
  city        String   @default("Austin")
  state       String   @default("TX")
  zip         String
  units       Int
  contactName String
  contactEmail String
  contactPhone String?
  stripeSessionId String?
  paid        Boolean  @default(false)
  paidAt      DateTime?
  amountCents Int?
  createdAt   DateTime @default(now())
}

model ContractorWaitlist {
  id           String   @id @default(cuid())
  company      String
  contactName  String
  email        String
  phone        String?
  category     String
  zip          String
  city         String   @default("Austin")
  state        String   @default("TX")
  stripeSessionId String?
  paid         Boolean  @default(false)
  paidAt       DateTime?
  position     Int?
  createdAt    DateTime @default(now())
}
